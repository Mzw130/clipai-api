# ==================== 环境 ====================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ==================== 数据库 ====================
# MySQL 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=clipai
MYSQL_PASSWORD=clipai_pass
MYSQL_DATABASE=clipai
REDIS_URL=redis://localhost:6379

# ==================== AI 服务 ====================
# Replicate (主 AI 引擎)
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stable Diffusion WebUI / RunPod 端点
SD_ENDPOINT=https://your-sd-instance.runpod.io
SD_API_KEY=

# 备用模型端点
INSIGHTFACE_ENDPOINT=http://localhost:7860
REMBG_ENDPOINT=http://localhost:7000

# ==================== 对象存储 (Cloudflare R2 / AWS S3) ====================
OSS_ENDPOINT=https://xxxxxxxx.r2.cloudflarestorage.com
OSS_ACCESS_KEY=xxxxxxxx
OSS_SECRET_KEY=xxxxxxxx
OSS_BUCKET=clipai
OSS_PUBLIC_URL=https://cdn.clipai.com
OSS_REGION=auto

# ==================== JWT ====================
JWT_SECRET=change-me-to-a-random-secret-string
JWT_EXPIRES_IN=7d

# ==================== 短信 / 验证码 ====================
# 阿里云短信
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=xxxxxxxx
SMS_SECRET_KEY=xxxxxxxx
SMS_SIGN_NAME=ClipAI
SMS_TEMPLATE_CODE=SMS_123456789

# ==================== 内容审核 ====================
CONTENT_MODERATION_ENDPOINT=https://api.aliyun.com/green/image/scan
CONTENT_MODERATION_KEY=xxxxxxxx

# ==================== 支付验证 ====================
# Apple App Store 票据验证
APPLE_SHARED_SECRET=xxxxxxxx
APPLE_VERIFY_RECEIPT_URL=https://buy.itunes.apple.com/verifyReceipt
APPLE_VERIFY_SANDBOX_URL=https://sandbox.itunes.apple.com/verifyReceipt

# ==================== 日志 ====================
LOG_LEVEL=info

# ==================== 限制 ====================
# 图片上传限制
MAX_IMAGE_SIZE_MB=20
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,heic

# 频率限制 (每分钟)
RATE_LIMIT_FREE=5
RATE_LIMIT_PRO=30

# 积分配置
FREE_DAILY_CREDITS=5
PRO_MONTHLY_CREDITS=200
